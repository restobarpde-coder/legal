# Supabase (safe to expose only the NEXT_PUBLIC values)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encrypts Hostinger account passwords at rest. Generate 32 random bytes in hex.
INBOX_ENCRYPTION_KEY=
# Protects the scheduled IMAP synchronization endpoint.
CRON_SECRET=
# Bearer token generated by Hostinger Agentic Mail after creating the webhook.
HOSTINGER_EMAIL_WEBHOOK_SECRET=
# Optional per-mailbox tokens as JSON, for example {"contacto@example.com":"token"}.
HOSTINGER_EMAIL_WEBHOOK_SECRETS={}
# Meta WhatsApp Cloud API — server only
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Email sync scheduling (minutes). Configure your scheduler to call POST /api/email/sync.
IMAP_SYNC_INTERVAL=5
